<link rel="stylesheet" href="/output.css">
<div class="flex justify-center items-center flex-col">

    <h1 class="text-2xl font-bold text-emerald-600 mb-1">Hello, <%= firstname %> 👋</h1>
    <p class="text-gray-500 mb-6">Share something with the club</p>
</div>

<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">

        <h1 class="text-2xl font-bold text-emerald-600 mb-1">Hello, <%= firstname %> 👋</h1>
        <p class="text-gray-500 mb-6">Share something with the club</p>

        <form action="" method="post" class="space-y-4">
            <div>
                <label for="title" class="block mb-1 font-medium text-gray-700">Title</label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    required
                    placeholder="Post title..."
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                >
            </div>

            <div>
                <label for="description" class="block mb-1 font-medium text-gray-700">Description</label>
                <textarea 
                    id="description" 
                    name="description" 
                    required
                    rows="4"
                    placeholder="What's on your mind..."
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 resize-none"
                ></textarea>
            </div>

            <button 
                type="submit"
                class="w-full bg-emerald-600 text-white py-2 rounded-lg font-semibold hover:bg-emerald-700 transition"
            >
                Post
            </button>
            <a href="/dashboard" class="text-emerald-500 flex items-center justify-center">Return To Dashboard</a>
        </form>

    </div>
</div>