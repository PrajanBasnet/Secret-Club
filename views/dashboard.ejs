<!doctype html>
<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="./output.css" rel="stylesheet">
  <script src="https://kit.fontawesome.com/c6e6597e48.js" crossorigin="anonymous"></script>

</head>

<body class="bg-gray-800 text-white ">
  <nav>
    <div class=" sticky top-0 z-50  flex gap-4 text-white justify-between bg-emerald-700 m-4 p-3 rounded-2xl">
      <div class="flex justify-start ">
        <a href="" class="font-semibold text-lg">Club House</a>
      </div>

      <% if(!userid) {%>
        <div class="flex gap-8">
          <a href="/auth/signup" class="hover:text-blue-400">Signup</a>
          <a href="/auth/login" class="hover:text-blue-400">Login</a>
        </div>
        <% } else{ %>

          <div><i class="fa-regular fa-user gap-3 cursor-pointer"></i>
            <button class="hover:cursor-pointer" command="show-modal" commandfor="my-dialog">
              <%=userid.firstname %>
            </button>
            <% if(!userid.member_status) { %>
              <a href="/riddle" class="hover:text-blue-400 mx-3">Join The Club</a>
              <%} %>
          </div>
          <% } %>
    </div>
  </nav>

  <!-- Post bar -->
  <div
    class="flex flex-col items-center bg-gray-700 h-[calc(100vh-2rem)] mx-14 md:mx-10 lg:mx-40 rounded-2xl  overflow-hidden p-1">
    <h1 class="text-3xl  p-4 font-bold">
      Daily Post
    </h1>

    <% data.forEach(post=>{ %>
      <% if(post.title) {%>
        <div class="bg-gray-600 p-6 my-3 mx-3 gap-6  w-3xl rounded-3xl hover:cursor-pointer">
          <p class="text-xl font-bold ">
            <%= post.title %>
          </p>
          <p class="text-lg ">
            <%= post.description %>
          </p>
          <p class="text-gray-500 text-lg">
            <%= userid ? post.username : "Anonymus" %>
          </p>
        </div>
        <% } %>
          <% }) %>

  </div>

  <!--  Logout Dialog -->
  <dialog id="my-dialog" class="rounded-3xl backdrop:bg-black/50">
    <div class="w-[400px] bg-white rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="bg-emerald-600 p-5 text-white">
        <h2 class="text-2xl font-bold">Club Menu</h2>
        <p class="text-emerald-100 text-sm">Manage your account</p>
      </div>

      <!-- Content -->
      <div class="p-6">
        <a href="/post/all"
          class="flex items-center justify-center w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 rounded-xl transition duration-200">
          ✍️ Create a Message
        </a>
      </div>

      <!-- Footer -->
      <div class="flex gap-3 p-6 border-t bg-gray-50">
        <form action="/auth/logout" method="POST">
        <button class="flex-1 bg-red-500 hover:bg-red-600 text-white font-semibold py-5 px-5 rounded-xl transition"
          type="submit">
            Logout
          </button>
        </form>

        <button class="flex-1 bg-gray-500 hover:bg-gray-600 text-white font-semibold py-3 rounded-xl transition"
          commandfor="my-dialog" command="close">
          Close
        </button>
      </div>

    </div>
  </dialog>
</body>

</html>